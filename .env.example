[TEMPLATE]
# Groq API key (server-side only — never exposed to the frontend)
GROQ_API_KEY=gsk_xxx

# Postgres connection string (use Supabase pooler for IPv4 compatibility)
DATABASE_URL=postgresql://postgres.user_ref:password@aws-region.pooler.supabase.com:6543/postgres

# Supabase credentials (for Storage — service role, keep secret!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=your-bucket-name

# Your full Airbnb referral link (generated by Airbnb — do not manually construct)
AIRBNB_REFERRAL_URL=https://www.airbnb.com/r/your-username

# CORS — the domain your frontend runs on
CORS_ORIGIN=https://sidebusiness.online

# Cookie signing secret
COOKIE_SECRET=change-me-to-a-random-string

# IP hashing salt (optional, for GDPR-friendly logging)
IP_SALT=change-me-too

NODE_ENV=development
PORT=3000
