# ── sidebusiness.online — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ── Server ───────────────────────────────────
PORT=3000
NODE_ENV=development
COOKIE_SECRET=change-this-to-a-random-secret-string
CORS_ORIGIN=*

# ── Database (Postgres / Supabase) ────────────────────
DATABASE_URL=postgresql://postgres.user:password@aws-region.pooler.supabase.com:6543/postgres

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=sunnhost-photos

# ── Groq AI (for chat + photo analysis) ────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ── Airbnb Affiliate ───────────────────────────
AIRBNB_REFERRAL_URL=https://www.airbnb.com/r/sidebusiness

# ── Security ──────────────────────────────
IP_SALT=change-this-to-another-random-string
